# Copy to .env and set real values. The app refuses to boot without SECRET_KEY (F-003).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Optional. Defaults shown.
DATABASE_URI=sqlite:///tasks.db
DEBUG=false
HOST=127.0.0.1
PORT=5000
TOKEN_TTL_SECONDS=3600

# Comma-separated allowed origins. Empty means no cross-origin access (F-002).
CORS_ORIGINS=
